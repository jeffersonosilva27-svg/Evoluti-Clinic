{
  "entities": {
    "UserProfile": {
      "title": "Perfil do Usuário",
      "description": "Dados do profissional ou administrador",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["ADM_SISTEMA", "GESTOR", "PROFISSIONAL", "RECEPCIONISTA"] },
        "status": { "type": "string", "enum": ["active", "pending"] },
        "clinics": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "clinics"]
    },
    "Clinic": {
      "title": "Unidade / Clínica",
      "description": "Unidades de atendimento",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Patient": {
      "title": "Paciente",
      "description": "Dados do paciente",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "clinicId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "clinicId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Perfis de usuários"
    },
    "/clinics/{clinicId}": {
      "schema": "Clinic",
      "description": "Lista de clínicas"
    },
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Lista de pacientes"
    },
    "/appointments/{appId}": {
      "schema": "object",
      "description": "Agendamentos"
    },
    "/evolutions/{evoId}": {
      "schema": "object",
      "description": "Evoluções clínicas"
    },
    "/financial/{recordId}": {
      "schema": "object",
      "description": "Registros financeiros"
    },
    "/assessmentTemplates/{templateId}": {
      "schema": "object",
      "description": "Templates de avaliação"
    },
    "/deletedAssessmentTemplates/{templateId}": {
      "schema": "object",
      "description": "Templates deletados"
    }
  }
}
